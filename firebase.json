{
  "firestore": {
    "rules": "firestore.rules",
    "indexes": "firestore.indexes.json"
  },
  "storage": {
    "rules": "storage.rules"
  },
  "hosting": {
    "public": "dist",
    "ignore": [
      "firebase.json",
      "**/.*",
      "**/node_modules/**"
    ],
    "headers": [
      {
        "source": "/index.html",
        "headers": [
          { "key": "Cache-Control", "value": "no-cache, no-store, must-revalidate" }
        ]
      },
      {
        "source": "/assets/**",
        "headers": [
          { "key": "Cache-Control", "value": "public, max-age=31536000, immutable" }
        ]
      }
    ],
    "rewrites": [
      {
        "source": "/api/ai/chat",
        "function": {
          "functionId": "apiAiChat",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/tts",
        "function": {
          "functionId": "apiTextToSpeech",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/payments/momo/initiate",
        "function": {
          "functionId": "apiCreateMomoPayment",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/payments/momo/status",
        "function": {
          "functionId": "apiMomoPaymentStatus",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/telegram/webhook",
        "function": {
          "functionId": "telegramWebhook",
          "region": "us-central1"
        }
      },
      {
        "source": "/api/zed/chat",
        "function": {
          "functionId": "apiZedAssistantChat",
          "region": "us-central1"
        }
      },
      {
        "source": "**",
        "destination": "/index.html"
      }
    ]
  },
  "functions": [
    {
      "source": "functions",
      "codebase": "default",
      "disallowLegacyRuntimeConfig": true,
      "ignore": [
        "node_modules",
        ".git",
        "firebase-debug.log",
        "firebase-debug.*.log",
        "*.local"
      ]
    }
  ]
}
