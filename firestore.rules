rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function callerRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return isAuthed() && callerRole() == 'admin'; }
    function isTeacherOrAbove() { return isAuthed() && (callerRole() == 'teacher' || callerRole() == 'admin'); }
    function incoming() { return request.resource.data; }

    // ── users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthed() && (isOwner(userId) || isTeacherOrAbove());
      allow create: if isAuthed() && isOwner(userId)
        && (incoming().role == 'learner' || incoming().role == 'teacher')
        && incoming().isPremium == false;
      // Self-update: cannot change role or subscription fields
      allow update: if isAuthed() && isOwner(userId)
        && !('role' in request.resource.data.diff(resource.data).affectedKeys())
        && !('isPremium' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionPlan' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionExpiry' in request.resource.data.diff(resource.data).affectedKeys())
        && !('subscriptionActivatedBy' in request.resource.data.diff(resource.data).affectedKeys());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── quizzes ───────────────────────────────────────────────
    match /quizzes/{quizId} {
      allow read: if isAuthed() && (
        resource.data.isPublished == true || isTeacherOrAbove()
        || resource.data.createdBy == request.auth.uid
      );
      allow create: if isTeacherOrAbove() && incoming().createdBy == request.auth.uid;
      allow update: if isAdmin() || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid);
      allow delete: if isAdmin() || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid);

      match /questions/{questionId} {
        allow read: if isAuthed();
        allow create, update: if isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid);
        allow delete: if isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid);
      }
    }

    // ── results ───────────────────────────────────────────────
    match /results/{resultId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
        || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.createdBy == request.auth.uid)
      );
      allow create: if isAuthed() && incoming().userId == request.auth.uid;
      allow update: if isAuthed() && resource.data.userId == request.auth.uid;
      allow delete: if isAdmin();
    }

    // ── papers ────────────────────────────────────────────────
    match /papers/{paperId} {
      allow read: if isAuthed();
      allow create: if isTeacherOrAbove() && incoming().uploadedBy == request.auth.uid;
      allow update: if isAdmin() || (isTeacherOrAbove() && resource.data.uploadedBy == request.auth.uid);
      allow delete: if isAdmin() || (isTeacherOrAbove() && resource.data.uploadedBy == request.auth.uid);
    }

    // ── payments ──────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      allow create: if isAuthed() && incoming().userId == request.auth.uid && incoming().status == 'pending' && incoming().confirmedBy == null;
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }
  }
}
