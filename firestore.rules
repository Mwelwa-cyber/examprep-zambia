rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    function isAuthed() { return request.auth != null; }
    function isOwner(uid) { return request.auth.uid == uid; }
    function callerRole() { return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role; }
    function isAdmin() { return isAuthed() && callerRole() == 'admin'; }
    function isTeacherOrAbove() { return isAuthed() && (callerRole() == 'teacher' || callerRole() == 'admin'); }
    function incoming() { return request.resource.data; }
    function changedKeys() { return request.resource.data.diff(resource.data).affectedKeys(); }
    // Teachers cannot set isPublished:true or status:'published'
    function teacherNotPublishing() {
      return incoming().isPublished == false
        && incoming().get('status', 'draft') != 'published';
    }
    function approvedTeacherApplicationAfter(userId) {
      return getAfter(/databases/$(database)/documents/teacherApplications/$(userId)).data.status == 'approved';
    }
    function validTeacherStatus(value) {
      return value in ['not_submitted', 'pending'];
    }
    function userSelfTeacherApplicationUpdate(userId) {
      return !changedKeys().hasAny(['teacherApplicationStatus', 'teacherApplicationId', 'teacherApplicationSubmittedAt'])
        || (
          changedKeys().hasOnly(['teacherApplicationStatus', 'teacherApplicationId', 'teacherApplicationSubmittedAt'])
          && incoming().teacherApplicationStatus == 'pending'
          && incoming().teacherApplicationId == userId
          && incoming().teacherApplicationSubmittedAt == request.time
          && getAfter(/databases/$(database)/documents/teacherApplications/$(userId)).data.status == 'pending'
        );
    }
    function adminUserUpdateAllowed(userId) {
      return !changedKeys().hasAny(['role'])
        || incoming().role != 'teacher'
        || approvedTeacherApplicationAfter(userId);
    }
    function validTeacherProofType(value) {
      return value in [
        'application/pdf',
        'image/jpeg',
        'image/png',
        'image/webp',
        'application/vnd.openxmlformats-officedocument.wordprocessingml.document'
      ];
    }
    function validTeacherApplicationCreate(userId) {
      return incoming().keys().hasOnly([
          'userId', 'email', 'fullName', 'phoneNumber', 'schoolName', 'nrcNumber',
          'proofPath', 'proofFileName', 'proofContentType', 'proofSize',
          'status', 'submittedAt', 'reviewedBy', 'reviewedAt', 'rejectionReason'
        ])
        && incoming().keys().hasAll([
          'userId', 'email', 'fullName', 'phoneNumber', 'schoolName', 'nrcNumber',
          'proofPath', 'proofFileName', 'proofContentType', 'proofSize',
          'status', 'submittedAt', 'reviewedBy', 'reviewedAt', 'rejectionReason'
        ])
        && userId == request.auth.uid
        && incoming().userId == userId
        && incoming().email is string
        && incoming().email.size() <= 254
        && incoming().fullName is string
        && incoming().fullName.size() >= 2
        && incoming().fullName.size() <= 120
        && incoming().phoneNumber is string
        && incoming().phoneNumber.size() >= 7
        && incoming().phoneNumber.size() <= 24
        && incoming().schoolName is string
        && incoming().schoolName.size() >= 2
        && incoming().schoolName.size() <= 160
        && incoming().nrcNumber is string
        && incoming().nrcNumber.size() >= 6
        && incoming().nrcNumber.size() <= 24
        && incoming().proofPath is string
        && incoming().proofPath.matches('teacher-verification/' + userId + '/.+')
        && incoming().proofFileName is string
        && incoming().proofFileName.size() >= 1
        && incoming().proofFileName.size() <= 140
        && incoming().proofContentType is string
        && validTeacherProofType(incoming().proofContentType)
        && incoming().proofSize is int
        && incoming().proofSize > 0
        && incoming().proofSize <= 10 * 1024 * 1024
        && incoming().status == 'pending'
        && incoming().submittedAt == request.time
        && incoming().reviewedBy == null
        && incoming().reviewedAt == null
        && incoming().rejectionReason == '';
    }
    function validTeacherApplicationReview() {
      return resource.data.status == 'pending'
        && incoming().keys().hasOnly([
          'userId', 'email', 'fullName', 'phoneNumber', 'schoolName', 'nrcNumber',
          'proofPath', 'proofFileName', 'proofContentType', 'proofSize',
          'status', 'submittedAt', 'reviewedBy', 'reviewedAt', 'rejectionReason'
        ])
        && incoming().userId == resource.data.userId
        && incoming().email == resource.data.email
        && incoming().fullName == resource.data.fullName
        && incoming().phoneNumber == resource.data.phoneNumber
        && incoming().schoolName == resource.data.schoolName
        && incoming().nrcNumber == resource.data.nrcNumber
        && incoming().proofPath == resource.data.proofPath
        && incoming().proofFileName == resource.data.proofFileName
        && incoming().proofContentType == resource.data.proofContentType
        && incoming().proofSize == resource.data.proofSize
        && incoming().submittedAt == resource.data.submittedAt
        && incoming().status in ['approved', 'rejected']
        && incoming().reviewedBy == request.auth.uid
        && incoming().reviewedAt == request.time
        && incoming().rejectionReason is string
        && incoming().rejectionReason.size() <= 500
        && (incoming().status == 'rejected' || incoming().rejectionReason == '');
    }

    // ── content-field validators ─────────────────────────────
    // These are data-integrity backstops, NOT authorization checks.
    // They only constrain fields that are present in the incoming doc, so
    // older documents without newer fields continue to pass. They defend
    // against bad client code and tampered clients that bypass UI validation.
    function _validGrade(value) { return value is string && value in ['4', '5', '6', '7']; }
    function _validSubject(value) { return value is string && value.size() >= 1 && value.size() <= 80; }
    function _validContentStatus(value) { return value is string && value in ['draft', 'pending', 'published', 'rejected']; }
    function _validQuestionType(value) { return value is string && value in ['mcq', 'short_answer', 'diagram']; }

    function validQuizFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        && (!('duration' in incoming()) || (incoming().duration is int && incoming().duration >= 5 && incoming().duration <= 180))
        && (!('totalMarks' in incoming()) || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 10000))
        && (!('questionCount' in incoming()) || (incoming().questionCount is int && incoming().questionCount >= 0 && incoming().questionCount <= 1000))
        && (!('status' in incoming()) || _validContentStatus(incoming().status))
        && (!('isPublished' in incoming()) || incoming().isPublished is bool);
    }

    function validQuestionFields() {
      return (!('type' in incoming()) || _validQuestionType(incoming().type))
        && (!('marks' in incoming()) || (incoming().marks is int && incoming().marks >= 1 && incoming().marks <= 10))
        && (!('options' in incoming()) || (incoming().options is list && incoming().options.size() <= 20))
        && (!('order' in incoming()) || (incoming().order is int && incoming().order >= 0 && incoming().order <= 1000))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200));
    }

    function validLessonFields() {
      return (!('title' in incoming()) || (incoming().title is string && incoming().title.size() >= 1 && incoming().title.size() <= 200))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject))
        && (!('topic' in incoming()) || (incoming().topic is string && incoming().topic.size() <= 200))
        && (!('status' in incoming()) || _validContentStatus(incoming().status))
        && (!('isPublished' in incoming()) || incoming().isPublished is bool);
    }

    function validResultFields() {
      return (!('score' in incoming()) || (incoming().score is number && incoming().score >= 0))
        && (!('percentage' in incoming()) || (incoming().percentage is number && incoming().percentage >= 0 && incoming().percentage <= 100))
        && (!('totalMarks' in incoming()) || (incoming().totalMarks is int && incoming().totalMarks >= 0 && incoming().totalMarks <= 10000))
        && (!('grade' in incoming()) || _validGrade(incoming().grade))
        && (!('subject' in incoming()) || _validSubject(incoming().subject));
    }

    // ── users ─────────────────────────────────────────────────
    match /users/{userId} {
      allow read: if isAuthed() && (isOwner(userId) || isTeacherOrAbove());
      allow create: if isAuthed() && isOwner(userId)
        && incoming().role == 'learner'
        && incoming().get('plan', 'free') == 'free'
        && incoming().get('premium', false) == false
        && incoming().isPremium == false
        && incoming().get('paymentStatus', 'inactive') == 'inactive'
        && incoming().get('subscriptionStatus', 'inactive') == 'inactive'
        && incoming().get('subscriptionPlan', 'free') == 'free'
        && incoming().get('subscriptionExpiry', null) == null
        && incoming().get('subscriptionActivatedBy', null) == null
        && incoming().get('subscriptionActivatedAt', null) == null
        && incoming().get('premiumActivatedAt', null) == null
        && incoming().get('subscriptionProvider', null) == null
        && incoming().get('subscriptionPaymentId', null) == null
        && incoming().get('subscriptionPhoneNumber', null) == null
        && (!('teacherApplicationStatus' in incoming()) || validTeacherStatus(incoming().teacherApplicationStatus));
      // Self-update: cannot change role or subscription fields
      allow update: if isAuthed() && isOwner(userId)
        && !changedKeys().hasAny([
          'role', 'plan', 'premium', 'isPremium', 'paymentStatus', 'subscriptionStatus',
          'premiumActivatedAt', 'subscriptionPlan', 'subscriptionExpiry', 'subscriptionActivatedBy',
          'subscriptionActivatedAt', 'subscriptionProvider', 'subscriptionPaymentId',
          'subscriptionPhoneNumber',
          'teacherApprovedBy', 'teacherApprovedAt', 'teacherRejectedBy', 'teacherRejectedAt',
          'teacherRejectionReason'
        ])
        && userSelfTeacherApplicationUpdate(userId);
      allow update: if isAdmin() && adminUserUpdateAllowed(userId);
      allow delete: if isAdmin();
    }

    // ── teacher verification applications ─────────────────────
    match /teacherApplications/{applicationId} {
      allow read: if isAuthed() && (applicationId == request.auth.uid || isAdmin());
      allow create: if isAuthed()
        && applicationId == request.auth.uid
        && validTeacherApplicationCreate(applicationId);
      allow update: if isAdmin() && validTeacherApplicationReview();
      allow delete: if isAdmin();
    }

    // ── quizzes ───────────────────────────────────────────────
    match /quizzes/{quizId} {
      allow read: if isAuthed() && (
        resource.data.isPublished == true || isTeacherOrAbove()
        || resource.data.createdBy == request.auth.uid
      );
      // Admin: create anything. Teacher: only draft/pending (cannot publish directly)
      allow create: if validQuizFields() && (
        (isAdmin() && incoming().createdBy == request.auth.uid)
        || (isTeacherOrAbove() && incoming().createdBy == request.auth.uid && teacherNotPublishing())
      );
      // Admin: update anything. Teacher: only own non-published content, cannot publish.
      allow update: if validQuizFields() && (
        isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false && teacherNotPublishing())
      );
      // Admin can delete anything; teachers can only delete their own unpublished content
      allow delete: if isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false);

      match /questions/{questionId} {
        allow read: if isAuthed();
        allow create, update: if validQuestionFields() && (
          isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid)
        );
        allow delete: if isAdmin()
          || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(quizId)).data.createdBy == request.auth.uid);
      }
    }

    // ── results ───────────────────────────────────────────────
    match /results/{resultId} {
      allow read: if isAuthed() && (
        resource.data.userId == request.auth.uid || isAdmin()
        || (isTeacherOrAbove() && get(/databases/$(database)/documents/quizzes/$(resource.data.quizId)).data.createdBy == request.auth.uid)
      );
      allow create: if isAuthed() && incoming().userId == request.auth.uid && validResultFields();
      allow update: if isAuthed() && resource.data.userId == request.auth.uid && validResultFields();
      allow delete: if isAdmin();
    }

    // ── lessons ───────────────────────────────────────────────
    match /lessons/{lessonId} {
      // Learners can only read published; teachers can read their own or any (if teacher+); admin reads all
      allow read: if isAuthed() && (
        resource.data.isPublished == true || isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid)
      );
      // Admin: create anything. Teacher: only draft/pending.
      allow create: if validLessonFields() && (
        (isAdmin() && incoming().createdBy == request.auth.uid)
        || (isTeacherOrAbove() && incoming().createdBy == request.auth.uid && teacherNotPublishing())
      );
      // Admin: update anything. Teacher: own non-published content only, cannot publish.
      allow update: if validLessonFields() && (
        isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false && teacherNotPublishing())
      );
      allow delete: if isAdmin()
        || (isTeacherOrAbove() && resource.data.createdBy == request.auth.uid
            && resource.data.isPublished == false);
    }

    // ── payments ──────────────────────────────────────────────
    match /payments/{paymentId} {
      allow read: if isAuthed() && (resource.data.userId == request.auth.uid || isAdmin());
      allow update: if isAdmin();
      allow delete: if isAdmin();
    }

    // ── aiGenerations (teacher tools) ─────────────────────────
    match /aiGenerations/{genId} {
      allow read:   if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
      // Client never creates these — only the Cloud Function does (admin SDK bypasses rules).
      allow create: if false;
      // Teachers can update their own generations' output (in-place editing)
      // and the teacherEdited / visibility / exportedFormats metadata fields.
      // Structural fields (tool, ownerUid, inputs, tokens, etc.) remain
      // immutable from the client.
      allow update: if isAuthed()
                       && resource.data.ownerUid == request.auth.uid
                       && changedKeys().hasOnly([
                         'output', 'teacherEdited', 'visibility', 'exportedFormats',
                       ])
                       && incoming().ownerUid == resource.data.ownerUid
                       && incoming().tool == resource.data.tool;
      // Admin can update anything (for moderation, flag/unflag etc.)
      allow update: if isAdmin();
      allow delete: if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── teacherLibraries ──────────────────────────────────────
    match /teacherLibraries/{uid} {
      allow read: if isAuthed() && (isOwner(uid) || isAdmin());
      match /items/{itemId} {
        allow read, write, delete: if isAuthed() && isOwner(uid);
      }
      match /folders/{folderId} {
        allow read, write, delete: if isAuthed() && isOwner(uid);
      }
    }

    // ── usageMeters ───────────────────────────────────────────
    match /usageMeters/{uid} {
      allow read: if isAuthed() && (isOwner(uid) || isAdmin());
      match /periods/{periodId} {
        allow read:  if isAuthed() && (isOwner(uid) || isAdmin());
        allow write: if false;  // Cloud Functions only (admin SDK).
      }
    }

    // ── private CBC curriculum grounding ─────────────────────
    // These collections hold the raw server-side curriculum corpus used to
    // ground AI generations. They must never be exposed to the browser.
    match /curriculum/{docId} {
      allow read, write: if false;
    }
    match /rag_chunks/{docId} {
      allow read, write: if false;
    }

    // ── cbcKnowledgeBase ──────────────────────────────────────
    match /cbcKnowledgeBase/{version} {
      allow read:  if isAuthed();
      allow write: if isAdmin();
      match /topics/{topicId} {
        allow read:  if isAuthed();
        allow write: if isAdmin();
      }
    }

    // ── promptTemplates ───────────────────────────────────────
    // Admin-only. Never exposed to non-admin clients.
    match /promptTemplates/{toolId} {
      allow read:  if isAdmin();
      allow write: if isAdmin();
      match /versions/{versionId} {
        allow read, write: if isAdmin();
      }
    }

    // ── schoolLicences ────────────────────────────────────────
    match /schoolLicences/{licenceId} {
      allow read:  if isAuthed() && (request.auth.uid in resource.data.memberUids || isAdmin());
      allow write: if isAdmin();
    }

    // ── games (public read, admin write) ──────────────────────
    // Students play games anonymously. Admins curate/seed content.
    // Document shape:
    //   { title, subject, grade, type, difficulty, description, timer,
    //     points, active, cbc_topic, questions[], generator?,
    //     createdAt, updatedAt, createdBy }
    match /games/{gameId} {
      allow read:   if resource.data.get('active', true) == true || isAdmin();
      allow create, update, delete: if isAdmin();
    }

    // ── scores (student-submitted play results) ───────────────
    // Read: public (powers leaderboards — only name + score leak out).
    // Create: signed-in players only; can only write their own userId.
    // Update/delete: admin only (prevents tampering with leaderboards).
    match /scores/{scoreId} {
      allow read:   if true;
      allow create: if isAuthed()
        && incoming().userId == request.auth.uid
        && incoming().gameId is string
        && incoming().score is number
        && incoming().grade is number
        && incoming().subject is string
        && incoming().playedAt == request.time;
      allow update, delete: if isAdmin();
    }

    // ── leaderboards (aggregated top-N per game; Cloud Function writes) ─
    match /leaderboards/{gameId} {
      allow read:  if true;
      allow write: if isAdmin();  // Cloud Functions also bypass via admin SDK
    }

    // ── badges (per-user earned badges) ───────────────────────
    // Self-awarded game badges are OK — the client evaluates against the
    // score just saved to `scores`. Tampering is low-stakes (the leaderboard
    // still uses real scores, badges are decorative). Admin moderates.
    match /badges/{userId} {
      allow read:          if isAuthed() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthed() && isOwner(userId);
      allow delete:        if isAdmin();
    }

    // ── daily_challenges (one featured game per day) ──────────
    // Docs are keyed by ISO date (YYYY-MM-DD). Empty collection is fine
    // — the client falls back to a deterministic rotation when no doc exists.
    match /daily_challenges/{dateId} {
      allow read:  if true;
      allow write: if isAdmin();
    }

    // ── dailyStreaks (per-user streak counter for the daily challenge) ──
    // Single doc per user: { streak, longestStreak, lastPlayedDate, lastGameId }
    match /dailyStreaks/{userId} {
      allow read:          if isAuthed() && (isOwner(userId) || isAdmin());
      allow create, update: if isAuthed() && isOwner(userId);
      allow delete:        if isAdmin();
    }

    // ── shares (public read-only snapshots of teacher generations) ─
    // Teachers publish a plan to the web via a share button. The doc is
    // keyed by a random token (doc ID = token) and contains a snapshot
    // of the plan at share-time (so later edits don't change what the
    // share URL shows). The token IS the share URL — knowing it is
    // permission to read. Anyone with the link can view; only the
    // owner (or admin) can update or unpublish.
    //
    // Document shape:
    //   { tool, ownerUid, title, plan, subject, grade, topic, createdAt, revokedAt? }
    match /shares/{token} {
      // Always readable — the token IS the permission. Client checks
      // `revokedAt` and shows the appropriate "revoked" / "not found"
      // state instead of the read failing with permission-denied.
      allow read: if true;
      allow create: if isAuthed()
        && incoming().ownerUid == request.auth.uid
        && incoming().keys().hasAll(['tool', 'ownerUid', 'title', 'plan', 'createdAt'])
        && incoming().tool is string
        && incoming().tool.size() <= 40
        && incoming().title is string
        && incoming().title.size() <= 200
        && incoming().plan is map
        && incoming().createdAt == request.time;
      allow update: if isAuthed()
        && resource.data.ownerUid == request.auth.uid
        && changedKeys().hasOnly(['revokedAt', 'title']);
      allow update: if isAdmin();
      allow delete: if isAuthed() && (resource.data.ownerUid == request.auth.uid || isAdmin());
    }

    // ── waitlist (public create, admin-only read) ─────────────
    // Anyone — even unauthenticated visitors — can submit one entry. Strict
    // field validation prevents junk; admin dashboard consumes reads.
    //
    // Admin updates are limited to two operational fields: `contacted` (bool)
    // and `notes` (string, ≤500 chars). This prevents accidental corruption
    // of the original submission data.
    match /waitlist/{entryId} {
      allow read:   if isAdmin();
      allow delete: if isAdmin();
      allow update: if isAdmin()
        && changedKeys().hasOnly(['contacted', 'notes', 'contactedAt'])
        && (!('contacted' in incoming()) || incoming().contacted is bool)
        && (!('notes' in incoming()) ||
            (incoming().notes is string && incoming().notes.size() <= 500));
      allow create: if
           incoming().keys().hasOnly([
             'email', 'fullName', 'schoolName', 'role',
             'grade', 'subject', 'source',
             'createdAt', 'userAgent'
           ])
        && incoming().keys().hasAll(['email', 'createdAt'])
        && incoming().email is string
        && incoming().email.matches('^[^@\\s]+@[^@\\s]+\\.[^@\\s]+$')
        && incoming().email.size() <= 254
        && (!('fullName' in incoming()) ||
            (incoming().fullName is string && incoming().fullName.size() <= 120))
        && (!('schoolName' in incoming()) ||
            (incoming().schoolName is string && incoming().schoolName.size() <= 160))
        && (!('role' in incoming()) ||
            (incoming().role is string && incoming().role.size() <= 40))
        && (!('grade' in incoming()) ||
            (incoming().grade is string && incoming().grade.size() <= 20))
        && (!('subject' in incoming()) ||
            (incoming().subject is string && incoming().subject.size() <= 40))
        && (!('source' in incoming()) ||
            (incoming().source is string && incoming().source.size() <= 60))
        && (!('userAgent' in incoming()) ||
            (incoming().userAgent is string && incoming().userAgent.size() <= 500))
        && incoming().createdAt == request.time;
    }
  }
}
