{
  "name": "examprep-zambia",
  "private": true,
  "version": "1.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test:importer": "node src/components/quiz/documentQuizParserCore.test.js && node src/components/quiz/documentQuizTableBlocks.test.js",
    "test:sanitize": "node scripts/test-rich-text-sanitize.mjs",
    "test:schema": "node scripts/test-question-schema.mjs",
    "test:all": "npm run test:importer && npm run test:sanitize && npm run test:schema",
    "migrate:questions:dry": "node scripts/migrate-questions-to-v3.mjs",
    "migrate:questions:live": "node scripts/migrate-questions-to-v3.mjs --live",
    "check:integrity": "node scripts/check-file-integrity.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "deploy:firebase:functions": "npx -y firebase-tools@latest deploy --only functions",
    "deploy:firebase:firestore": "npx -y firebase-tools@latest deploy --only firestore",
    "preview": "vite preview",
    "android:sync": "vite build && cap sync android",
    "android:open": "cap open android",
    "android:run": "vite build && cap run android",
    "android:apk:debug": "npm run android:sync && cd android && ./gradlew assembleDebug",
    "android:apk:release": "npm run android:sync && cd android && ./gradlew assembleRelease"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint --fix",
    "*.{js,jsx,mjs,cjs,ts,tsx,json,md,mdx,html,css,scss}": "node scripts/check-file-integrity.mjs"
  },
  "dependencies": {
    "@capacitor/android": "^7.6.2",
    "@capacitor/app": "^7.1.2",
    "@capacitor/core": "^7.6.2",
    "@capacitor/status-bar": "^7.0.6",
    "@heroicons/react": "^2.2.0",
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.3",
    "@tiptap/extension-superscript": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "docx": "^9.6.1",
    "dompurify": "^3.4.0",
    "fflate": "^0.8.2",
    "file-saver": "^2.0.5",
    "firebase": "^11.10.0",
    "katex": "^0.16.45",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.6.2",
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "firebase-admin": "^13.8.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
