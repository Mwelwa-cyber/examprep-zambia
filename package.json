{
  "name": "examprep-zambia",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "test:importer": "node src/components/quiz/documentQuizParserCore.test.js && node src/components/quiz/documentQuizTableBlocks.test.js",
    "check:integrity": "node scripts/check-file-integrity.mjs",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "prepare": "husky",
    "deploy": "npm run deploy:netlify",
    "deploy:netlify": "npm run build && npx -y netlify-cli deploy --prod --dir=dist --site=5a7c0fa9-62b2-4137-a109-8a7478bf6148",
    "deploy:netlify:preview": "npm run build && npx -y netlify-cli deploy --dir=dist --site=5a7c0fa9-62b2-4137-a109-8a7478bf6148",
    "deploy:firebase:hosting": "npm run build && npx -y firebase-tools@latest deploy --only hosting",
    "deploy:firebase:functions": "npx -y firebase-tools@latest deploy --only functions",
    "deploy:firebase:firestore": "npx -y firebase-tools@latest deploy --only firestore",
    "preview": "vite preview"
  },
  "lint-staged": {
    "src/**/*.{js,jsx}": "eslint --fix",
    "*.{js,jsx,mjs,cjs,ts,tsx,json,md,mdx,html,css,scss}": "node scripts/check-file-integrity.mjs"
  },
  "dependencies": {
    "@tiptap/core": "^3.22.3",
    "@tiptap/extension-color": "^3.22.3",
    "@tiptap/extension-highlight": "^3.22.3",
    "@tiptap/extension-placeholder": "^3.22.3",
    "@tiptap/extension-subscript": "^3.22.3",
    "@tiptap/extension-superscript": "^3.22.3",
    "@tiptap/extension-table": "^3.22.3",
    "@tiptap/extension-table-cell": "^3.22.3",
    "@tiptap/extension-table-header": "^3.22.3",
    "@tiptap/extension-table-row": "^3.22.3",
    "@tiptap/extension-text-align": "^3.22.3",
    "@tiptap/extension-text-style": "^3.22.3",
    "@tiptap/extension-underline": "^3.22.3",
    "@tiptap/react": "^3.22.3",
    "@tiptap/starter-kit": "^3.22.3",
    "docx": "^9.6.1",
    "dompurify": "^3.4.0",
    "fflate": "^0.8.2",
    "file-saver": "^2.0.5",
    "firebase": "^10.14.1",
    "katex": "^0.16.45",
    "lucide-react": "^0.454.0",
    "pdfjs-dist": "^4.10.38",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-router-dom": "^6.20.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.4",
    "@vitejs/plugin-react": "^4.2.0",
    "autoprefixer": "^10.4.16",
    "eslint": "^9.39.4",
    "eslint-plugin-promise": "^7.2.1",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^15.15.0",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.4.32",
    "tailwindcss": "^3.3.6",
    "vite": "^5.0.0"
  }
}
