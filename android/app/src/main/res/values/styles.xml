<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme. -->
    <style name="AppTheme" parent="Theme.AppCompat.Light.DarkActionBar">
        <!-- Customize your theme here. -->
        <item name="colorPrimary">@color/colorPrimary</item>
        <item name="colorPrimaryDark">@color/colorPrimaryDark</item>
        <item name="colorAccent">@color/colorAccent</item>
    </style>

    <style name="AppTheme.NoActionBar" parent="Theme.AppCompat.DayNight.NoActionBar">
        <item name="windowActionBar">false</item>
        <item name="windowNoTitle">true</item>
        <item name="android:background">@null</item>
        <!-- Tint the system bars with the brand violet so the OS clock,
             signal, battery and gesture icons sit on the same colour as the
             app, and switch them to white. The Capacitor StatusBar plugin
             reasserts these from JS, but matching them in the theme avoids
             a one-frame flash of the OEM default on cold start. -->
        <item name="android:statusBarColor">#4C1D95</item>
        <item name="android:windowLightStatusBar">false</item>
        <item name="android:navigationBarColor">#4C1D95</item>
        <item name="android:windowLightNavigationBar">false</item>
        <!-- Android 15 (SDK 35) enforces edge-to-edge for apps targeting it,
             which lets the WebView draw over the system bars. Opt out so the
             system bars remain solid and the time / signal / battery stay
             visible above the app. -->
        <item name="android:windowOptOutEdgeToEdgeEnforcement">true</item>
    </style>


    <style name="AppTheme.NoActionBarLaunch" parent="Theme.SplashScreen">
        <item name="android:background">@drawable/splash</item>
        <!-- Hand off to the regular activity theme once the splash dismisses
             so the status / nav bar settings above actually take effect. -->
        <item name="postSplashScreenTheme">@style/AppTheme.NoActionBar</item>
    </style>
</resources>